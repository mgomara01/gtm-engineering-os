# Public browser-safe configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_DEMO_MODE=true

# Server-only configuration — never expose with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_DSN=
POSTHOG_KEY=
APP_ENCRYPTION_KEY=
CRON_SECRET=

# Production switches
ENABLE_OUTBOUND_COMMUNICATIONS=false
ENABLE_AUTOMATED_AGENT_WRITES=false
ENABLE_PRODUCTION_IMPORTS=false
